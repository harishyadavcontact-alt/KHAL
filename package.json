{
  "name": "khal",
  "version": "0.1.0",
  "description": "KHAL decision operating system monorepo (War Room ontology, war-gaming, mission command, execution).",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --check .",
    "quality:gate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/quality-gate.ps1",
    "ci:audit": "node scripts/audit-workflows.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs --baseUrl=http://localhost:3010",
    "perf:smoke": "node scripts/perf-smoke.mjs --baseUrl=http://localhost:3010",
    "docs:sync": "npm run docs:render:decision-framework && npm run docs:render:genesis && npm run docs:validate",
    "docs:render:genesis": "node scripts/render-war-room-decision-tree.mjs",
    "docs:validate": "node scripts/validate-doc-artifacts.mjs",
    "docs:render:decision-framework": "node scripts/render-decision-framework.mjs",
    "qa:report": "node scripts/qa-report.mjs",
    "uat:capture": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uat-capture.ps1",
    "release:package:main": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-package-main.ps1",
    "parity:report": "node scripts/war-room-parity-report.mjs",
    "conformance": "npm run typecheck && npm run build && npm run parity:report",
    "db:init": "tsx scripts/bootstrap-sqlite.ts",
    "db:export:json": "tsx scripts/export-sqlite-json.ts",
    "db:export:csv": "tsx scripts/export-sqlite-csv.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
